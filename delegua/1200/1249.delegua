funcao rot13(c) {
    var code = c
    se code >= 97 e code <= 122 {
        retorna texto((code - 97 + 13) % 26 + 97)
    }
    se code >= 65 e code <= 90 {
        retorna texto((code - 65 + 13) % 26 + 65)
    }
    retorna texto(code)
}

var entrada = leia()
enquanto entrada != nulo e entrada != "" {
    var resultado = ""
    para cada c em entrada {
        resultado = resultado + rot13(c)
    }
    escreva(resultado)
    entrada = leia()
}
