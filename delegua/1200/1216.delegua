var soma = 0
var n = 0
enquanto verdadeiro {
    var linha = leia()
    se linha == nulo ou linha == "" {
        sustar
    }
    var partes = linha.dividir(" ")
    para cada p em partes {
        se p != "" {
            soma = soma + inteiro(p)
            n = n + 1
        }
    }
}
// Saida da media com 1 casa decimal
var media = soma / n
escreva("${media}")
