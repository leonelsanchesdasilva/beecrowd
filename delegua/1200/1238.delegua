var n = inteiro(leia())
para var i = 0; i < n; i++ {
    var linha = leia()
    var partes = linha.dividir(" ")
    var a = partes[0]
    var b = partes[1]
    var resultado = ""
    var j = 0
    enquanto j < a.tamanho() ou j < b.tamanho() {
        se j < a.tamanho() {
            resultado = resultado + a[j]
        }
        se j < b.tamanho() {
            resultado = resultado + b[j]
        }
        j = j + 1
    }
    escreva(resultado)
}
