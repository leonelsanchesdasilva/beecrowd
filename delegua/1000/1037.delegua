var a = numero(leia())
se a >= 0 e a <= 25 {
    escreva("Intervalo [0,25]")
} senao se a > 25 e a <= 50 {
    escreva("Intervalo (25,50]")
} senao se a > 50 e a <= 75 {
    escreva("Intervalo (50,75]")
} senao se a > 75 e a <= 100 {
    escreva("Intervalo (75,100]")
} senao {
    escreva("Fora de intervalo")
}
