var o = leia()
var nums = []
para var i = 0; i < 144; i++ {
    nums.adicionar(numero(leia()))
}
var soma = 0.0
para var j = 1; j <= 12; j++ {
    para var i = 13 - j; i <= j - 2; i++ {
        soma = soma + nums[i * 12 + j]
    }
}
se o == "S" {
    escreva(soma)
} senao {
    escreva(soma / 30)
}
