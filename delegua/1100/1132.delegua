var linha = leia()
var partes = linha.dividir(" ")
var a = inteiro(partes[0])
var b = inteiro(partes[1])
var soma = 0
se a <= b {
    para var i = a; i <= b; i++ {
        se i % 13 != 0 {
            soma = soma + i
        }
    }
} senao {
    para var i = a; i >= b; i-- {
        se i % 13 != 0 {
            soma = soma + i
        }
    }
}
escreva(soma)
