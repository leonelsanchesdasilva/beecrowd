var fat = []
fat.adicionar(1)
para var i = 1; i <= 20; i++ {
    fat.adicionar(fat[i - 1] * i)
}

enquanto verdadeiro {
    var linha = leia()
    se linha == nulo ou linha == "" {
        sustar
    }
    var partes = linha.dividir(" ")
    var s1 = inteiro(partes[0])
    var s2 = inteiro(partes[1])
    escreva(fat[s1] + fat[s2])
}
