var n = inteiro(leia())
para var i = 0; i < n; i++ {
    var k = inteiro(leia())
    var s = []
    para var j = 0; j < k; j++ {
        s.adicionar(leia())
    }
    var primeiro = s[0]
    var iguais = verdadeiro
    para var j = 1; j < s.tamanho(); j++ {
        se s[j] != primeiro {
            iguais = falso
        }
    }
    se iguais {
        escreva("${s[0]}")
    } senao {
        escreva("ingles")
    }
}
