var x = inteiro(leia())
para var i = 0; i < x; i++ {
    var a = leia().dividir(" ")
    var b = leia().dividir(" ")
    var media = numero(a[1]) / numero(a[0])
    var b1 = numero(b[0])
    var b2 = numero(b[1])
    var b3 = numero(b[2])
    var matematica = importar("matematica")
    var temp = (media * 3 * (b2 - b1) / (3.14159265358979 * b3) + b1 ^ 3) ^ (1/3)
    escreva("${media * 3 / (3.14159265358979 * (temp ^ 2 + temp * b1 + b1 ^ 2))}")
}
