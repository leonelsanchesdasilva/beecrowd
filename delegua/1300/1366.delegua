// 1366 - Quadrados a tarde
// Le n pares, conta quantos retangulos podem ser formados com angulos retos a partir de tabuas

enquanto verdadeiro {
    var l = leia()
    se l == nulo ou l == "" { sustar }
    var n = inteiro(l)
    se n == 0 { sustar }
    var pares = 0
    para var i = 0; i < n; i++ {
        var linha = leia()
        var p = linha.dividir(" ")
        var v = inteiro(p[1]) \ 2
        pares = pares + v
    }
    var retangulos = pares \ 2
    escreva(retangulos)
}
