var n = inteiro(leia())
enquanto n > 0 {
    var a = 0
    var b = 0
    para var i = 0; i < n; i++ {
        var jogo = leia()
        se jogo.tamanho() == 3 {
            se jogo[0] > jogo[2] { a = a + 1 }
            se jogo[0] < jogo[2] { b = b + 1 }
        } senao se jogo.tamanho() == 4 {
            se jogo[2] == " " {
                a = a + 1
            } senao {
                b = b + 1
            }
        }
    }
    escreva("${a} ${b}")
    n = inteiro(leia())
}
